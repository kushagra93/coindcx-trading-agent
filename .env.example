# ===== Service Mode =====
# Which worker to run: api | data-ingestion | signal-worker | executor
SERVICE_MODE=api

# ===== General =====
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DRY_RUN=true

# ===== Database =====
DATABASE_URL=postgresql://agent:agent@localhost:5432/trading_agent

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== AWS KMS =====
AWS_REGION=ap-south-1
AWS_KMS_KEY_ID=your-kms-key-id
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== Solana =====
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=your-helius-api-key

# ===== EVM =====
EVM_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
EVM_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_API_KEY=your-alchemy-api-key
DEFAULT_EVM_CHAIN_ID=137

# ===== Hyperliquid =====
HYPERLIQUID_MAINNET=false

# ===== DEX APIs =====
JUPITER_API_URL=https://quote-api.jup.ag/v6
ONEINCH_API_KEY=your-1inch-api-key
ZEROX_API_KEY=your-0x-api-key

# ===== Market Data =====
COINGECKO_API_KEY=your-coingecko-api-key

# ===== AI =====
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===== Host App Adapter =====
HOST_APP_ADAPTER=coindcx
COINDCX_API_URL=https://api.coindcx.com
COINDCX_API_KEY=your-coindcx-api-key
COINDCX_RELAY_URL=https://relay.coindcx.com

# ===== Fees =====
FEE_WALLET_ADDRESS_SOL=your-sol-fee-wallet
FEE_WALLET_ADDRESS_EVM=your-evm-fee-wallet
FEE_SETTLEMENT_THRESHOLD_USD=50

# ===== Risk =====
MAX_POSITION_SIZE_PCT=25
CIRCUIT_BREAKER_LOSS_PCT=10
CIRCUIT_BREAKER_WINDOW_HOURS=1
